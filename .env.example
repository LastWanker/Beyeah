# Backend database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=beyeah
DB_USER=root
DB_PASSWORD=replace_me

# Auth
APP_AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
APP_AUTH_TOKEN_EXPIRE_SECONDS=259200
APP_ADMIN_AUTH_TOKEN_SECRET=replace_with_another_long_random_secret
APP_ADMIN_AUTH_TOKEN_EXPIRE_SECONDS=43200
APP_AUTH_LOGIN_MAX_ATTEMPTS=5
APP_AUTH_LOGIN_WINDOW_SECONDS=600
APP_AUTH_LOGIN_LOCK_SECONDS=900

# Order auto-close
APP_ORDER_AUTO_CLOSE_SECONDS=1800
APP_ORDER_AUTO_CLOSE_BATCH_SIZE=100
APP_ORDER_AUTO_CLOSE_FIXED_DELAY_MS=60000

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:22223,http://127.0.0.1:22223,http://localhost:5173,http://127.0.0.1:5173
